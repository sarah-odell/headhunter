  <!-- Hero Section -->
  <section class="hero d-flex align-items-center">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-md-6 hero-text">
          <h1 class="hero-title">Hi. I'm Nidhi <br> Kumari</h1>
          <div class="hero-desc-container">
            <div class="hero-desc-line color-transition-text fancy-hero-desc">

              Driven by a passion for frontend development, I transform ideas into <span
                class="fancy-keyword">responsive</span>, <span class="fancy-keyword">accessible</span>, and <span
                class="fancy-keyword">user-focused</span> web applications.

            </div>
          </div>
        </div>
        <div class="col-md-6 text-center hero-image">
          <img src="Learn Javascript Now!.jpeg" alt="Frontend Development Concept" class="hero-img"
            style="max-width: 100%; height: auto; object-fit: contain;">
        </div>
      </div>
    </div>
  </section>

  <!-- Fixed Download Resume Button -->
