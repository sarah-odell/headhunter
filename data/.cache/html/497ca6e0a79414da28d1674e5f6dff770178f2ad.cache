<!doctype html>
<html lang="en" data-beasties-container>

<!-- Built by humans, guided by caffeine. -->

<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#007bff">
  <meta name="robots" content="index, follow">

  <!-- /// Structured Data (Google Rich Snippets) -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Coupyn",
    "url": "https://coupyn.com/",
    "description": "Discover verified coupons, referral codes and deals from 900k+ stores. Track real success rates, share your offers, and see what’s trending live on Coupyn.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "https://coupyn.com/deals?q={search_term_string}"
      },
      "query-input": "required name=search_term_string"
    }
  }
  </script>

  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Coupyn",
  "url": "https://coupyn.com/",
  "description": "Discover verified coupons, referral codes and deals from 900k+ stores. Track real success rates, share your offers, and see what’s trending live on Coupyn.",
  "applicationCategory": "Shopping",
  "operatingSystem": "Web browser",
  "softwareRequirements": "Built with Angular v21, Node.js/Express.js, MongoDB (MEAN stack)",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD",
    "category": "Subscription",
    "description": "Free access to Coupyn’s coupon and referral code platform."
  }
}
</script>

  <script>
    (function () {
      const stopStyle =
        "color:#fff;background:#d32f2f;font-size:32px;font-weight:700;padding:12px 60px;border-radius:10px;display:inline-block;text-align:center;";
      const warnStyle =
        "color:#b71c1c;font-size:14px;line-height:1.6;";
      const brandStyle =
        "color:#0d47a1;background:#e3f2fd;font-size:14px;padding:6px 10px;border-radius:6px;";
      const linkStyle =
        "color:#1565c0;font-weight:600;text-decoration:underline;";

      console.log("%c     STOP       ", stopStyle);

      console.warn(
        "%cThis console is for developers. If anyone asked you to paste code here, do not do it.\n" +
        "Pasting scripts can expose your account, cookies, or data.",
        warnStyle
      );

      console.log(
        "%cCoupyn is hand built. Coffee assisted.%c https://coupyn.com",
        brandStyle,
        linkStyle
      );

      console.groupCollapsed("What is this?");
      console.info(
        "Developers use this console to debug. If you are not expecting to be here, simply close it."
      );
      console.groupEnd();
    })();
  </script>

  <!-- /// Analytics and SDKs -->

  <script>
    (function () {
      var GA_ID = 'G-FF5ZW6NVH5';

      function getCookie(name) {
        var value = '; ' + document.cookie;
        var parts = value.split('; ' + name + '=');
        if (parts.length === 2) return parts.pop().split(';').shift();
        return null;
      }

      function loadAnalytics() {
        if (window['ga-disable-' + GA_ID]) return;
        if (window.__coupynAnalyticsLoaded) return;
        window.__coupynAnalyticsLoaded = true;

        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        window.gtag = gtag;
        gtag('js', new Date());
        gtag('config', GA_ID);

        var script = document.createElement('script');
        script.async = true;
        script.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA_ID;
        document.head.appendChild(script);
      }

      window.__coupynLoadAnalytics = loadAnalytics;

      var consent = getCookie('sitePerformanceCookies');
      if (consent === 'true') {
        loadAnalytics();
      }

      window.addEventListener('coupyn:cookieConsent', function (event) {
        var detail = event && event.detail;
        if (!detail) return;
        if (detail.consent === true) {
          window['ga-disable-' + GA_ID] = false;
          loadAnalytics();
          return;
        }
        if (detail.consent === false) {
          window['ga-disable-' + GA_ID] = true;
        }
      });
    })();
  </script>

  <!-- /// Stripe SDK is loaded on-demand via @stripe/stripe-js -->

  <!-- /// Main Title -->
  <title>Coupyn | Coupons, Referral Codes & Deals from 900k+ Stores</title>
  <base href="/">

  <!-- /// SEO Meta Tags -->
  <meta name="description" content="Discover verified coupons, referral codes and deals from 900k+ stores. Track real success rates, share your offers, and see what’s trending live on Coupyn.">
  <meta name="author" content="Coupyn">

  <!-- /// Open Graph / Facebook Meta Tags -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://coupyn.com/">
  <meta property="og:title" content="Coupyn | Coupons, Referral Codes &amp; Deals from 900k+ Stores">
  <meta property="og:description" content="Discover verified coupons, referral codes and deals from 900k+ stores. Track real success rates, share your offers, and see what’s trending live on Coupyn.">
  <meta property="og:image" content="https://coupyn.com/assets/coupyn_logo.png">

  <!-- /// X (Twitter) Meta Tags -->
  <meta property="twitter:card" content="summary_large_image">
  <meta property="twitter:url" content="https://coupyn.com/">
  <meta property="twitter:title" content="Coupyn | Coupons, Referral Codes &amp; Deals from 900k+ Stores">
  <meta property="twitter:description" content="Discover verified coupons, referral codes and deals from 900k+ stores. Track real success rates, share your offers, and see what’s trending live on Coupyn.">

  <!-- /// Favicon and Touch Icons -->
  <link rel="icon" type="image/x-icon" href="/assets/favicon.ico">
  <link rel="icon" type="image/png" sizes="192x192" href="/assets/android-chrome-192x192.png">
  <link rel="icon" type="image/png" sizes="512x512" href="/assets/android-chrome-512x512.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/favicon-16x16.png">
  <link rel="manifest" href="/assets/site.webmanifest">

  <!-- /// Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://backend.coupyn.com" crossorigin>
  <link rel="preconnect" href="https://media.coupyn.com" crossorigin>
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;500;600;700&amp;display=swap" onload="this.onload=null;this.rel='stylesheet'">
  <noscript>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  </noscript>
