    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
  </noscript>
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Pacifico&amp;display=swap" onload="this.onload=null;this.rel='stylesheet'">
  <noscript>
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&display=swap" rel="stylesheet">
  </noscript>

  <!-- Inline cookie banner styles -->
  <style>
    #cookie-inline-banner {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      width: 100%;
      z-index: 2147483640;
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: 0.75rem 1.5rem;
      align-items: center;
      padding: 1rem 1.5rem calc(1rem + env(safe-area-inset-bottom, 0px));
      border-radius: 0;
      background: #ffffff;
      border-top: 1px solid rgba(226, 232, 240, 0.9);
      color: #0f172a;
      box-shadow: 0 -12px 30px rgba(15, 23, 42, 0.12);
      box-sizing: border-box;
      font-family: "Open Sans", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 220ms ease, transform 220ms ease;
    }

    #cookie-inline-banner[data-visible] {
      opacity: 1;
      transform: translateY(0);
    }

    #cookie-inline-banner[hidden] {
      display: none !important;
    }

    html.drawer-cookie-hidden #cookie-inline-banner {
      display: none !important;
    }

    #cookie-inline-banner .cookie-inline__icon {
      position: relative;
      width: 46px;
      height: 46px;
      border-radius: 14px;
      background: linear-gradient(135deg, #1f2d4d, #72acf3);
      color: #ffffff;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 12px 26px rgba(67, 56, 202, 0.24);
    }

    #cookie-inline-banner .cookie-inline__body {
      position: relative;
      display: grid;
      gap: 0.3rem;
    }

    #cookie-inline-banner .cookie-inline__eyebrow {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #1f2d4d;
    }

    #cookie-inline-banner .cookie-inline__title {
      font-size: 1rem;
      font-weight: 700;
      margin: 0;
    }

    #cookie-inline-banner .cookie-inline__copy {
      margin: 0;
      font-size: 0.85rem;
      line-height: 1.5;
      color: #475569;
    }

    #cookie-inline-banner .cookie-inline__actions {
      position: relative;
      display: flex;
      gap: 0.6rem;
      flex-wrap: wrap;
      align-items: center;
      justify-content: flex-end;
    }

    #cookie-inline-banner button[data-action] {
      border: 1px solid transparent;
      border-radius: 999px;
      padding: 0.5rem 1.05rem;
      font-size: 0.85rem;
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      gap: 0;
      cursor: pointer;
      transition: background-color 160ms ease, color 160ms ease, transform 160ms ease, box-shadow 160ms ease;
      background: #eef2ff;
      color: #4338ca;
      white-space: nowrap;
    }

    #cookie-inline-banner .material-icons {
      font-family: "Material Icons";
      font-weight: normal;
      font-style: normal;
      line-height: 1;
      display: inline-block;
    }

    #cookie-inline-banner .cookie-inline__icon .material-icons {
      font-size: 24px;
    }


    #cookie-inline-banner button[data-action="manage"] {
      background: #eef2ff;
      color: #4338ca;
    }

    #cookie-inline-banner button[data-action="decline"] {
      background: #ffffff;
      border-color: rgba(148, 163, 184, 0.6);
      color: #475569;
    }

    #cookie-inline-banner button[data-action="accept"] {
      background: linear-gradient(135deg, #1f2d4d, #72acf3);
      color: #ffffff;
      box-shadow: 0 12px 24px rgba(67, 56, 202, 0.24);
    }

    #cookie-inline-banner button[data-action]:hover {
      transform: translateY(-1px);
    }

    @media (min-width: 1025px) {
      #cookie-inline-banner {
        left: auto;
        right: 24px;
        bottom: 24px;
        width: min(420px, 92vw);
        border-radius: 20px;
        border: 1px solid rgba(226, 232, 240, 0.9);
        box-shadow: 0 20px 40px rgba(15, 23, 42, 0.16);
        grid-template-columns: auto minmax(0, 1fr);
        padding: 1rem 1.25rem;
      }

      #cookie-inline-banner .cookie-inline__actions {
        grid-column: 1 / -1;
        justify-content: flex-end;
      }
    }

    @media (min-width: 767px) and (max-width: 1024px) {
      #cookie-inline-banner {
        left: 0;
        right: 0;
        width: 100%;
        border-radius: 0;
        border: 0;
        border-top: 1px solid rgba(226, 232, 240, 0.9);
        box-shadow: 0 -10px 26px rgba(15, 23, 42, 0.12);
        grid-template-columns: auto minmax(0, 1fr) auto;
        gap: 0.75rem 1rem;
        padding: 0.95rem 1.25rem calc(0.95rem + env(safe-area-inset-bottom, 0px));
      }

      #cookie-inline-banner .cookie-inline__actions {
        justify-content: flex-end;
        flex-wrap: nowrap;
        gap: 0.5rem;
      }

      #cookie-inline-banner button[data-action] {
        padding: 0.45rem 0.7rem;
        font-size: 0.78rem;
      }

      #cookie-inline-banner button[data-action] .material-icons {
        font-size: 16px;
      }
    }

    @media (max-width: 767px) {
      #cookie-inline-banner {
        grid-template-columns: auto minmax(0, 1fr);
        padding: 0.9rem 0.9rem calc(0.95rem + env(safe-area-inset-bottom, 0px));
      }

      #cookie-inline-banner .cookie-inline__icon {
        width: 42px;
        height: 42px;
      }

      #cookie-inline-banner .cookie-inline__body {
        grid-template-columns: 1fr;
        align-items: start;
        row-gap: 0.2rem;
      }

      #cookie-inline-banner .cookie-inline__eyebrow {
        margin: 0;
        font-size: 0.65rem;
        letter-spacing: 0.12em;
      }

      #cookie-inline-banner .cookie-inline__title {
        font-size: 0.9rem;
      }

      #cookie-inline-banner .cookie-inline__copy {
        font-size: 0.78rem;
      }

      #cookie-inline-banner .cookie-inline__actions {
        flex-direction: row;
        align-items: center;
        justify-content: center;
        flex-wrap: nowrap;
        width: 100%;
        gap: 0.4rem;
        grid-column: 1 / -1;
        display: flex;
      }

      #cookie-inline-banner button[data-action] {
        padding: 0.4rem 0.55rem;
        font-size: 0.72rem;
        justify-content: center;
      }

      #cookie-inline-banner button[data-action] .material-icons {
        font-size: 16px;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      #cookie-inline-banner {
        transition: none;
      }

      #cookie-inline-banner button[data-action] {
        transition: none;
      }
    }
  </style>

<style>:root{--coupyn-auth-gradient-default:radial-gradient(900px circle at 80% 50%, rgba(255, 174, 201, .45) 0%, rgba(255, 174, 201, .18) 35%, transparent 70%), radial-gradient(720px circle at 95% 72%, rgba(190, 148, 255, .35) 0%, transparent 62%), radial-gradient(1200px circle at 20% 70%, rgba(191, 255, 244, .35) 0%, transparent 65%), radial-gradient(1100px circle at 30% 10%, rgba(171, 198, 255, .45) 0%, transparent 70%), linear-gradient(180deg, #e9f2ff 0%, #f8fbff 40%, #f7fffe 100%);--coupyn-auth-gradient-mobile:radial-gradient(860px circle at 88% 220px, rgba(255, 174, 201, .5) 0%, rgba(255, 174, 201, .24) 36%, transparent 72%), radial-gradient(700px circle at 96% 520px, rgba(190, 148, 255, .4) 0%, transparent 64%), radial-gradient(1080px circle at 18% 760px, rgba(191, 255, 244, .3) 0%, transparent 64%), radial-gradient(1040px circle at 22% 140px, rgba(171, 198, 255, .26) 0%, transparent 72%), linear-gradient(180deg, #ecf4ff 0%, #fafcff 42%, #f8ffff 100%);--coupyn-auth-gradient:var(--coupyn-auth-gradient-default);--coupyn-referral-gradient-default:radial-gradient(1100px circle at 14% 24%, rgba(248, 113, 113, .2) 0%, rgba(248, 113, 113, 0) 56%), radial-gradient(980px circle at 88% 30%, rgba(251, 146, 60, .18) 0%, rgba(251, 146, 60, 0) 58%), radial-gradient(880px circle at 22% 88%, rgba(244, 114, 182, .14) 0%, rgba(244, 114, 182, 0) 62%), linear-gradient(180deg, #fff1f2 0%, #fff7ed 38%, #ffffff 100%);--coupyn-referral-gradient-mobile:radial-gradient(960px circle at 16% 260px, rgba(248, 113, 113, .22) 0%, rgba(248, 113, 113, 0) 58%), radial-gradient(900px circle at 92% 480px, rgba(251, 146, 60, .2) 0%, rgba(251, 146, 60, 0) 60%), radial-gradient(760px circle at 20% 940px, rgba(244, 114, 182, .16) 0%, rgba(244, 114, 182, 0) 62%), linear-gradient(180deg, #fff2f2 0%, #fff8ee 40%, #ffffff 100%);--coupyn-referral-gradient:var(--coupyn-referral-gradient-default)}body,html{margin:0;padding:0;height:100%;overflow-x:hidden!important;font-family:Open Sans,sans-serif!important