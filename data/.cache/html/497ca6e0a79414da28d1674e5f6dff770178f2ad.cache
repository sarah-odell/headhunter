<body class="mat-typography">

  <app-root></app-root>

  <div id="cookie-inline-banner" role="dialog" aria-live="polite" aria-label="Cookie preferences" hidden>
    <div class="cookie-inline__icon" aria-hidden="true">
      <span class="material-icons">cookie</span>
    </div>
    <div class="cookie-inline__body">
      <span class="cookie-inline__eyebrow">Cookie control</span>
      <p class="cookie-inline__title">Cookies keep Coupyn secure</p>
      <p class="cookie-inline__copy">
        We use essential cookies and optional ones to improve performance. Review preferences now or anytime.
      </p>
    </div>
    <div class="cookie-inline__actions">
      <button type="button" data-action="manage">Manage</button>
      <button type="button" data-action="decline">Decline</button>
      <button type="button" data-action="accept">Accept all</button>
    </div>
  </div>

  <script>
    (function () {
      var banner = document.getElementById('cookie-inline-banner');
      if (!banner) {
        return;
      }

      var getCookie = function (name) {
        var value = '; ' + document.cookie;
        var parts = value.split('; ' + name + '=');
        if (parts.length === 2) {
          return parts.pop().split(';').shift() || null;
        }
        return null;
      };

      var hasStoredConsent = function () {
        var consent = getCookie('cookieConsent');
        return consent === 'true' || consent === 'false';
      };

      var setPresenceHidden = function (hidden) {
        var root = document.documentElement;
        if (!root || !root.classList) {
          return;
        }
        if (hidden) {
          root.classList.add('cookie-banner-visible');
        } else {
          root.classList.remove('cookie-banner-visible');
        }
      };

      setPresenceHidden(false);

      if (hasStoredConsent()) {
        setPresenceHidden(false);
        return;
      }

      setPresenceHidden(true);

      var hideBanner = function () {
        banner.removeAttribute('data-visible');
        banner.setAttribute('hidden', '');
        setPresenceHidden(false);
      };

      var setCookie = function (name, value, days) {
        var expires = '';
        if (typeof days === 'number') {
          expires = '; max-age=' + (days * 86400);
        }
        var domain = '';
        var hostname = window.location && window.location.hostname;
        if (hostname && hostname !== 'localhost' && hostname.indexOf('.') > -1 && /coupyn\.com$/i.test(hostname)) {
          domain = '; domain=.coupyn.com';
        }
        var secure = window.location && window.location.protocol === 'https:' ? '; Secure' : '';
        document.cookie = name + '=' + encodeURIComponent(value) + expires + '; path=/' + domain + secure + '; SameSite=Lax';
      };

      var setOptionalCookies = function (value) {
        var names = [
          'userExperienceCookies',
          'sitePerformanceCookies',
          'customizationCookies',
          'targetedAdvertisingCookies'
        ];
        for (var i = 0; i < names.length; i++) {
          setCookie(names[i], value, 365);
        }
      };

      var showBanner = function () {
        banner.hidden = false;
        banner.setAttribute('data-visible', '');
        setPresenceHidden(true);
      };

      var scheduleShow = function () {
        var show = function () {
          if (hasStoredConsent()) {
            return;
          }
          showBanner();
        };
        if ('requestIdleCallback' in window) {
          window.requestIdleCallback(show, { timeout: 1800 });
        } else {
          setTimeout(show, 700);
        }
      };

      banner.addEventListener('click', function (event) {
        var target = event.target;
        if (!(target instanceof HTMLElement) || target.tagName !== 'BUTTON') {
          return;
        }

        var action = target.getAttribute('data-action');
        if (!action) {
          return;
        }

        if (action === 'accept') {
          setCookie('cookieConsent', 'true', 365);
          setOptionalCookies('true');
          hideBanner();
          window.dispatchEvent(new CustomEvent('coupyn:cookieConsent', { detail: { consent: true } }));
          return;
        }

        if (action === 'decline') {
          setCookie('cookieConsent', 'false', 365);
          setOptionalCookies('false');
          hideBanner();
          window.dispatchEvent(new CustomEvent('coupyn:cookieConsent', { detail: { consent: false } }));
          return;
        }

        if (action === 'manage') {
          window.__coupynCookieDialogRequested = true;
          hideBanner();
          window.dispatchEvent(new Event('coupyn:openCookieDialog'));
        }
      });

      scheduleShow();
    })();
  </script>

