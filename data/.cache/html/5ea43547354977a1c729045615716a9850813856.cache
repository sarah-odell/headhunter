        <div hidden class="create-custom-scope-form" data-target="custom-scopes.createCustomScopeForm">
        <!-- '"` --><!-- </textarea></xmp> --></option></form><form id="custom-scopes-dialog-form" data-turbo="false" action="/search/custom_scopes" accept-charset="UTF-8" method="post"><input type="hidden" data-csrf="true" name="authenticity_token" value="FfQ+K+7jSrJ1JLm8etXfKpfHW/rlP3wILucFXc4JRZtGtxlVPVk9aCyck7kzvWjuk1BovA29HSibcAyfWjZr5Q==" />
