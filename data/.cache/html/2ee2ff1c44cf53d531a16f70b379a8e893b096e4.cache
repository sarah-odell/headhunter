020ub-15 dvWzLQ"><a href="https://reactjs.org/" target="_blank" rel="noopener noreferrer" class="styles__KeywordInner-q020ub-16 eAFDJx">React</a></li><li class="styles__Keyword-q020ub-15 dvWzLQ"><a href="https://reactrouter.com/" target="_blank" rel="noopener noreferrer" class="styles__KeywordInner-q020ub-16 eAFDJx">React Router</a></li><li class="styles__Keyword-q020ub-15 dvWzLQ"><a href="https://styled-components.com/" target="_blank" rel="noopener noreferrer" class="styles__KeywordInner-q020ub-16 eAFDJx">Styled Components</a></li><li class="styles__Keyword-q020ub-15 dvWzLQ"><a href="https://www.javascript.com/" target="_blank" rel="noopener noreferrer" class="styles__KeywordInner-q020ub-16 eAFDJx">JavaScript</a></li><li class="styles__Keyword-q020ub-15 dvWzLQ"><a href="https://developer.mozilla.org/en-US/docs/Web/HTML" target="_blank" rel="noopener noreferrer" class="styles__KeywordInner-q020ub-16 eAFDJx">HTML</a></li><li class="styles__Keyword-q020ub-15 dvWzLQ"><a href="https://developer.mozilla.org/en-US/docs/Web/CSS" target="_blank" rel="noopener noreferrer" class="styles__KeywordInner-q020ub-16 eAFDJx">CSS</a></li></ul></div><a class="styles__Images-q020ub-4 gDNorp" href="/projects/movies"><div class="styles__ImagesInner-q020ub-5 kaKgVW"><div class="styles__ImageDesktop-q020ub-10 gjWTwp gatsby-image-wrapper" style="position:relative;overflow:hidden"><div aria-hidden="true" style="width:100%;padding-bottom:56.25%"></div><img aria-hidden="true" src="data:image/jpeg;base64," title="Movies - Desktop" alt="Movies - Desktop" style="position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;object-position:center;opacity:1;transition-delay:500ms"/><noscript><picture><source srcset="/static/55304d876c58e132f0d691525e5f5045/9104c/071add736e00db299786deca6d27de71a16ceba0-1920x1080.jpg 480w,
