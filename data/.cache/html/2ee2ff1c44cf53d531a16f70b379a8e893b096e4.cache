/static/1e79a3c9fcc37276bf9e928b11c3b2a1/05d05/6513818ad8b3d08c9bb4e1f71a1570f7a20492e9-1080x1920.png 1080w" src="/static/1e79a3c9fcc37276bf9e928b11c3b2a1/05d05/6513818ad8b3d08c9bb4e1f71a1570f7a20492e9-1080x1920.png" alt="Pairs - Mobile" title="Pairs - Mobile" style="position:absolute;top:0;left:0;opacity:1;width:100%;height:100%;object-fit:cover;object-position:center"/></picture></noscript></div></div></div></a></article><article class="styles__Item-q020ub-17 bMDBrS"><div class="styles__Content-q020ub-3 hvdyjf"><p class="styles__Subtitle-q020ub-2 jESeDX">2022-04-01</p><div class="flex-container"><h1 class="styles__Title-q020ub-1 iOzCcQ"><a class="styles__StyledLink-q020ub-11 kOHmcO" href="/projects/swallows">Swallows</a></h1><div class="styles__Container-p0gjzx-0 flQPQx"><a href="https://birds.rossdaniel.com" target="_blank" rel="noopener noreferrer" class="styles__Anchor-p0gjzx-1 iSVFaa"><i class="styles__Icon-p0gjzx-2 cJNSqb fas fa-globe fa-fw"></i></a></div></div><div class="styles__Text-q020ub-13 dXNoyC"><p>Get your fix of finches, pheasants, and fowl. A simple responsive gallery of bird images, created with vanilla HTML and CSS using a simple CSS grid layout and images from <a href="https://unsplash.com/">Unsplash</a>.</p></div><ul class="styles__Keywords-q020ub-14 gMCUNG"><li class="styles__Keyword-q020ub-15 dvWzLQ"><a href="https://developer.mozilla.org/en-US/docs/Web/HTML" target="_blank" rel="noopener noreferrer" class="styles__KeywordInner-q020ub-16 eAFDJx">HTML</a></li><li class="styles__Keyword-q020ub-15 dvWzLQ"><a href="https://developer.mozilla.org/en-US/docs/Web/CSS" target="_blank" rel="noopener noreferrer" class="styles__KeywordInner-q020ub-16 eAFDJx">CSS</a></li></ul></div><a class="styles__Images-q020ub-4 gDNorp" href="/projects/swallows"><div class="styles__ImagesInner-q020ub-5 kaKgVW"><div class="styles__ImageDesktop-q020ub-10 gjWTwp gatsby-image-wrapper" style="position:relative;overflow:hidden"><div aria-hidden="true" style="width:100%;paddi