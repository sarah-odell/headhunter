="width:28px;height:28px;border-radius:8px;background:#06b6d4;font-size:11px">E</div><div class="flex-1 min-w-0"><div style="color:#e2e8f0;font-size:10px;font-weight:600">E-Commerce App</div><div style="color:#475569;font-size:8px">Expo EAS</div></div><div class="shrink-0" style="width:6px;height:6px;border-radius:50%;background:#4ade80"></div></div><div class="flex items-center gap-2.5 py-1" style="opacity:0;transform:translateX(-12px)"><div class="flex items-center justify-center text-white font-bold shrink-0" style="width:28px;height:28px;border-radius:8px;background:#f97316;font-size:11px">L</div><div class="flex-1 min-w-0"><div style="color:#e2e8f0;font-size:10px;font-weight:600">Logistics Tracker</div><div style="color:#475569;font-size:8px">iOS · Android</div></div><div class="shrink-0" style="width:6px;height:6px;border-radius:50%;background:#4ade80"></div></div></div><div class="absolute bottom-0 left-0 right-0 flex items-center justify-around" style="height:52px;border-top:1px solid rgba(255,255,255,0.06);background:rgba(13,21,38,0.95);backdrop-filter:blur(8px);padding-bottom:6px"><div class="flex flex-col items-center justify-center gap-0.5"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-house" aria-hidden="true" style="width:14px;height:14px;color:#818cf8"><path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"></path><path d="M3 10a2 2 0 0 1 .709-1.528l7-6a2 2 0 0 1 2.582 0l7 6A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path></svg><div style="width:3px;height:3px;border-radius:50%;background:#818cf8"></div></div><div class="flex flex-col items-center justify-center gap-0.5"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-search" aria-hidden="true" style="width:14px;height:14px;color:#334155"><path d="m21 21-4.34-4.34"></path><circle cx="11" cy="11" r="8"></circle></svg></div><div class="flex flex-col items-center justify-center gap-0.5"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-bell" aria-hidden="true" style="width:14px;height:14px;color:#334155"><path d="M10.268 21a2 2 0 0 0 3.464 0"></path><path d="M3.262 15.326A1 1 0 0 0 4 17h16a1 1 0 0 0 .74-1.673C19.41 13.956 18 12.499 18 8A6 6 0 0 0 6 8c0 4.499-1.411 5.956-2.738 7.326"></path></svg></div><div class="flex flex-col items-center justify-center gap-0.5"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-user" aria-hidden="true" style="width:14px;height:14px;color:#334155"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg></div></div></div><div class="absolute inset-0 pointer-events-none" style="border-radius:42px;background:linear-gradient(135deg, rgba(255,255,255,0.07) 0%, transparent 45%)"></div></div></div></div><div class="absolute flex items-center gap-2 px-3 py-1.5 rounded-xl" style="top:30px;right:-10px;background:#1c2a3a;border:1px solid rgba(99,102,241,0.4);box-shadow:0 4px 20px rgba(99,102,241,0.2)"><div style="width:7px;height:7px;border-radius:50%;background:#61DAFB"></div><span style="color:#e2e8f0;font-size:10px;font-weight:600">React Native</span></div><div class="absolute flex items-center gap-1.5 px-3 py-1.5 rounded-xl" style="bottom:40px;left:-10px;background:#1c2a3a;border:1px solid rgba(139,92,246,0.4);box-shadow:0 4px 20px rgba(139,92,246,0.2)"><span style="font-size:10px">📱</span><span style="color:#e2e8f0;font-size:10px;font-weight:600">iOS &amp; Android</span></div><div class="absolute flex items-center gap-1.5 px-3 py-1.5 rounded-xl" style="bottom:90px;right:-14px;background:#1c2a3a;border:1px solid rgba(6,182,212,0.35);box-shadow:0 4px 16px rgba(6,182,212,0.15)"><div style="width:6px;height:6px;border-radius:2px;background:#06b6d4"></div><span style="color:#e2e8f0;font-size:10px;font-weight:600">Expo EAS</span></div></div></div></div></div></section><section id="about" class="py-24 bg-[var(--bg-page)]"><div class="max-w-6xl mx-auto px-6"><div class="text-center mb-16" style="opacity:0;transform:translateY(30px)"><span class="text-indigo-400 font-mono text-sm tracking-widest uppercase">Get to know me</span><h2 class="text-3xl md:text-4xl font-bold text-[var(--text-primary)] mt-3">About Me</h2></div><div class="grid lg:grid-cols-2 gap-16 items-center"><div style="opacity:0;transform:translateX(-40px)"><div class="space-y-5 text-[var(--text-secondary)] leading-relaxed"><p>I&#x27;m a<!-- --> <span class="text-white font-medium">Senior Full Stack Developer</span> <!-- -->with over 9 years of experience building scalable web and mobile applications. Based in<!-- --> <span class="text-indigo-400">London, UK</span>, I specialise in the React ecosystem — from responsive web apps with Next.js to cross-platform mobile apps with React Native.</p><p>At<!-- --> <span class="text-white font-medium">Anya Consultancy Services</span>, I&#x27;ve led development of high-traffic applications serving 50,000+ users, architected CI/CD pipelines, and championed TypeScript-first development standards. I&#x27;m passionate about developer experience and leverage AI-assisted tools (Claude in VS Code) to accelerate feature delivery.</p><p>Beyond writing code, I mentor junior developers and drive engineering best practices — reducing production bugs by 40% and deployment times by 60% through automation and strong tooling.</p></div><div class="mt-8 flex flex-wrap gap-3"><span class="px-3 py-1.5 bg-indigo-500/10 border border-indigo-500/20 text-indigo-500 dark:text-indigo-300 text-sm rounded-lg">React.js</span><span class="px-3 py-1.5 bg-indigo-500/10 border border-indigo-500/20 text-indigo-500 dark:text-indigo-300 text-sm rounded-lg">Next.js</span><span class="px-3 py-1.5 bg-indigo-500/10 border border-indigo-500/20 text-indigo-500 dark:text-indigo-300 text-sm rounded-lg">React Native</span><span class="px-3 py-1.5 bg-indigo-500/10 border border-indigo-500/20 text-indigo-500 dark:text-indigo-300 text-sm rounded-lg">TypeScript</span><span class="px-3 py-1.5 bg-indigo-500/10 border border-indigo-500/20 text-indigo-500 dark:text-indigo-300 text-sm rounded-lg">Node.js</span><span class="px-3 py-1.5 bg-indigo-500/10 border border-indigo-500/20 text-indigo-500 dark:text-indigo-300 text-sm rounded-lg">MongoDB</span><span class="px-3 py-1.5 bg-indigo-500/10 border border-indigo-500/20 text-indigo-500 dark:text-indigo-300 text-sm rounded-lg">Azure</span><span class="px-3 py-1.5 bg-indigo-500/10 border border-indigo-500/20 text-indigo-500 dark:text-indigo-300 text-sm rounded-lg">GraphQL</span></div></div><div class="grid grid-cols-2 gap-4" style="opacity:0;transform:translateX(40px)"><div class="p-6 rounded-2xl bg-[var(--bg-card)] border border-[var(--border-soft)] hover:border-indigo-500/30 transition-all group" style="opacity:0;transform:scale(0.9)"><div class="w-10 h-10 rounded-xl bg-indigo-500/10 flex items-center justify-center mb-4 group-hover:bg-indigo-500/20 transition-colors"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-briefcase w-5 h-5 text-indigo-400" aria-hidden="true"><path d="M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path><rect width="20" height="14" x="2" y="6" rx="2"></rect></svg></div><div class="text-3xl font-bold text-[var(--text-primary)] mb-1"><span>0<!-- -->+</span></div><div class="text-sm text-[var(--text-muted)]">Years Experience</div></div><div clas