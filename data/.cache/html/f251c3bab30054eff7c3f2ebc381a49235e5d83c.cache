cx="12" cy="10" r="3"></circle></svg>Bengaluru, India</span></div></div><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-down w-5 h-5 text-[var(--text-muted)] shrink-0 mt-1 transition-transform" aria-hidden="true"><path d="m6 9 6 6 6-6"></path></svg></div><div class="flex flex-wrap gap-2 mt-3"><span class="px-2.5 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-secondary)] text-xs rounded-md">Ionic</span><span class="px-2.5 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-secondary)] text-xs rounded-md">Cordova</span><span class="px-2.5 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-secondary)] text-xs rounded-md">Angular</span><span class="px-2.5 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-secondary)] text-xs rounded-md">Adobe Photoshop</span><span class="px-2.5 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-secondary)] text-xs rounded-md">Illustrator</span></div></div></div></div><div class="relative md:pl-12" style="opacity:0;transform:translateX(-30px)"><div class="absolute left-0 top-6 hidden md:flex items-center justify-center w-9 h-9 rounded-full bg-[var(--bg-page)] border-2 border-indigo-500/50 shadow-lg shadow-indigo-500/20"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-briefcase w-4 h-4 text-indigo-400" aria-hidden="true"><path d="M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path><rect width="20" height="14" x="2" y="6" rx="2"></rect></svg></div><div class="rounded-2xl border transition-all cursor-pointer bg-[var(--bg-card)] border-[var(--border-soft)] hover:border-indigo-500/20"><div class="p-5"><div class="flex items-start justify-between gap-4"><div class="flex-1"><div class="flex items-center gap-2 flex-wrap mb-1"><h3 class="text-[var(--text-primary)] font-semibold text-lg">Frontend Developer</h3></div><p class="text-indigo-400 font-medium">iStudio Technology</p><div class="flex items-center gap-4 mt-2 text-sm text-[var(--text-muted)]"><span class="flex items-center gap-1"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar w-3.5 h-3.5" aria-hidden="true"><path d="M8 2v4"></path><path d="M16 2v4"></path><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M3 10h18"></path></svg>November 2016 – July 2017</span><span class="flex items-center gap-1"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin w-3.5 h-3.5" aria-hidden="true"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"></path><circle cx="12" cy="10" r="3"></circle></svg>Chennai, India</span></div></div><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-down w-5 h-5 text-[var(--text-muted)] shrink-0 mt-1 transition-transform" aria-hidden="true"><path d="m6 9 6 6 6-6"></path></svg></div><div class="flex flex-wrap gap-2 mt-3"><span class="px-2.5 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-secondary)] text-xs rounded-md">Ionic</span><span class="px-2.5 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-secondary)] text-xs rounded-md">Cordova</span><span class="px-2.5 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-secondary)] text-xs rounded-md">Angular</span><span class="px-2.5 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-secondary)] text-xs rounded-md">HTML</span><span class="px-2.5 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-secondary)] text-xs rounded-md">CSS</span></div></div></div></div><div class="relative md:pl-12" style="opacity:0;transform:translateX(-30px)"><div class="absolute left-0 top-6 hidden md:flex items-center justify-center w-9 h-9 rounded-full bg-[var(--bg-page)] border-2 border-indigo-500/50 shadow-lg shadow-indigo-500/20"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-briefcase w-4 h-4 text-indigo-400" aria-hidden="true"><path d="M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path><rect width="20" height="14" x="2" y="6" rx="2"></rect></svg></div><div class="rounded-2xl border transition-all cursor-pointer bg-[var(--bg-card)] border-[var(--border-soft)] hover:border-indigo-500/20"><div class="p-5"><div class="flex items-start justify-between gap-4"><div class="flex-1"><div class="flex items-center gap-2 flex-wrap mb-1"><h3 class="text-[var(--text-primary)] font-semibold text-lg">Software Engineer</h3></div><p class="text-indigo-400 font-medium">Accel Frontline</p><div class="flex items-center gap-4 mt-2 text-sm text-[var(--text-muted)]"><span class="flex items-center gap-1"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar w-3.5 h-3.5" aria-hidden="true"><path d="M8 2v4"></path><path d="M16 2v4"></path><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M3 10h18"></path></svg>August 2015 – November 2016</span><span class="flex items-center gap-1"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin w-3.5 h-3.5" aria-hidden="true"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"></path><circle cx="12" cy="10" r="3"></circle></svg>Chennai, India</span></div></div><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-down w-5 h-5 text-[var(--text-muted)] shrink-0 mt-1 transition-transform" aria-hidden="true"><path d="m6 9 6 6 6-6"></path></svg></div><div class="flex flex-wrap gap-2 mt-3"><span class="px-2.5 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-secondary)] text-xs rounded-md">JavaScript</span><span class="px-2.5 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-secondary)] text-xs rounded-md">HTML</span><span class="px-2.5 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-secondary)] text-xs rounded-md">CSS</span><span class="px-2.5 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-secondary)] text-xs rounded-md">jQuery</span></div></div></div></div></div></div></div></section><section id="projects" class="py-24 bg-[var(--bg-alt)]"><div class="max-w-6xl mx-auto px-6"><div class="text-center mb-16" style="opacity:0;transform:translateY(30px)"><span class="text-indigo-400 font-mono text-sm tracking-widest uppercase">What I&#x27;ve built</span><h2 class="text-3xl md:text-4xl font-bold text-[var(--text-primary)] mt-3">Key Projects</h2><p class="text-[var(--text-muted)] mt-4 max-w-xl mx-auto">Real-world applications built for enterprise clients, NHS hospitals, fintech companies, and logistics providers.</p></div><div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5"><div class="group relative p-6 rounded-2xl bg-[var(--bg-card)] border border-[var(--border-soft)] hover:border-indigo-500/40 transition-all hover:-translate-y-1 hover:shadow-2xl hover:shadow-black/30 cursor-default" style="opacity:0;transform:translateY(30px)"><div class="flex items-start justify-between mb-4"><div class="w-12 h-12 rounded-xl bg-indigo-500/10 flex items-center justify-center"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-smartphone w-6 h-6 text-indigo-400" aria-hidden="true"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"></rect><path d="M12 18h.01"></path></svg></div><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-external-link w-4 h-4 text-[var(--text-faint)] group-hover:text-[var(--text-muted)] transition-colors mt-1" aria-hidden="true"><path d="M15 3h6v6"></path><path d="M10 14 21 3"></path><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path></svg></div><div class="mb-1"><span class="text-xs font-medium text-indigo-400">Mobile Application</span></div><h3 class="text-[var(--text-primary)] font-semibold text-lg mb-3 leading-tight">Terrapin Mobile App</h3><p class="text-[var(--text-muted)] text-sm leading-relaxed mb-4">Led development of a cross-platform mobile application with seamless iOS and Android compatibility. Implemented optimized performance with EAS Build deployment pipeline.</p><div class="mb-4"><span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs border bg-indigo-500/10 text-indigo-400 border-indigo-500/20">Cross-platform • iOS &amp; Android</span></div><div class="flex flex-wrap gap-1.5"><span class="px-2 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-muted)] text-xs rounded">React Native Expo</span><span class="px-2 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-muted)] text-xs rounded">EAS</span><span class="px-2 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-muted)] text-xs rounded">TypeScript</span><span class="px-2 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-muted)] text-xs rounded">.NET</span></div></div><div class="group relative p-6 rounded-2xl bg-[var(--bg-card)] border border-[var(--border-soft)] hover:border-purple-500/40 transition-all hover:-translate-y-1 hover:shadow-2xl hover:shadow-black/30 cursor-default" style="opacity:0;transform:translateY(30px)"><div class="flex items-start justify-between mb-4"><div class="w-12 h-12 rounded-xl bg-purple-500/10 flex items-center justify-center"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-credit-card w-6 h-6 text-purple-400" aria-hidden="true"><rect width="20" height="14" x="2" y="5" rx="2"></rect><line x1="2" x2="22" y1="10" y2="10"></line></svg></div><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-external-link w-4 h-4 text-[var(--text-faint)] group-hover:text-[var(--text-muted)] transition-colors mt-1" aria-hidden="true"><path d="M15 3h6v6"></path><path d="M10 14 21 3"></path><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path></svg></div><div class="mb-1"><span class="text-xs font-medium text-purple-400">Fintech Mobile App</span></div><h3 class="text-[var(--text-primary)] font-semibold text-lg mb-3 leading-tight">Oodle Finance</h3><p class="text-[var(--text-muted)] text-sm leading-relaxed mb-4">Built a fintech mobile application with secure authentication, payment processing, and seamless cross-platform performance. Integrated Apollo GraphQL for efficient data fetching.</p><div class="mb-4"><span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs border bg-purple-500/10 text-purple-400 border-purple-500/20">50K+ users • Fintech</span></div><div class="flex flex-wrap gap-1.5"><span class="px-2 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-muted)] text-xs rounded">React Native Expo</span><span class="px-2 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-muted)] text-xs rounded">EAS</span><span class="px-2 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-muted)] text-xs rounded">TypeScript</span><span class="px-2 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-muted)] text-xs rounded">Apollo GraphQL</span><span class="px-2 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-muted)] text-xs rounded">Node.js</span></div></div><div class="group relative p-6 rounded-2xl bg-[var(--bg-card)] border border-[var(--border-soft)] hover:border-cyan-500/40 transition-all hover:-translate-y-1 hover:shadow-2xl hover:shadow-black/30 cursor-default" style="opacity:0;transform:translateY(30px)"><div class="flex items-start justify-between mb-4"><div class="w-12 h-12 rounded-xl bg-cyan-500/10 flex items-center justify-center"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-globe w-6 h-6 text-cyan-400" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"></path><path d="M2 12h20"></path></svg></div><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-external-link w-4 h-4 text-[var(--text-faint)] group-hover:text-[var(--text-muted)] transition-colors mt-1" aria-hidden="true"><path d="M15 3h6v6"></path><path d="M10 14 21 3"></path><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path></svg></div><div class="mb-1"><span class="text-xs font-medium text-cyan-400">Healthcare • NHS UK</span></div><h3 class="text-[var(--text-primary)] font-semibold text-lg mb-3 leading-tight">ACS Life Web Application</h3><p class="text-[var(--text-muted)] text-sm leading-relaxed mb-4">Developed a comprehensive catering management system for NHS-based hospitals in the UK. Scalable Next.js application handling hospital-wide food ordering and logistics.</p><div class="mb-4"><span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs border bg-cyan-500/10 text-cyan-400 border-cyan-500/20">NHS UK • Enterprise Scale</span></div><div class="flex flex-wrap gap-1.5"><span class="px-2 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-muted)] text-xs rounded">Next.js</span><span class="px-2 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-muted)] text-xs rounded">React.js</span><span class="px-2 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-muted)] text-xs rounded">.NET</span></div></div><div class="group relative p-6 rounded-2xl bg-[var(--bg-card)] border border-[var(--border-soft)] hover:border-green-500/40 transition-all hover:-translate-y-1 hover:shadow-2xl hover:shadow-black/30 cursor-default" style="opacity:0;transform:translateY(30px)"><div class="flex items-start justify-between mb-4"><div class="w-12 h-12 rounded-xl bg-green-500/10 flex items-center justify-center"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shopping-cart w-6 h-6 text-green-400" aria-hidden="true"><circle cx="8" cy="21" r="1"></circle><circle cx="19" cy="21" r="1"></circle><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"></path></svg></div><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-external-link w-4 h-4 text-[var(--text-faint)] group-hover:text-[var(--text-muted)] transition-colors mt-1" aria-hidden="true"><path d="M15 3h6v6"></path><path d="M10 14 21 3"></path><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path></svg></div><div class="mb-1"><span class="text-xs font-medium text-green-400">Customer App &amp; EPOS</span></div><h3 class="text-[var(--text-primary)] font-semibold text-lg mb-3 leading-tight">Queen Elizabeth Hospital</h3><p class="text-[var(--text-muted)] text-sm leading-relaxed mb-4">Integrated customer ordering app and point-of-sale system with DOJO payment gateway, cash processing, and receipt printer integration for real-time order management.</p><div class="mb-4"><span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs border bg-green-500/10 text-green-400 border-green-500/20">EPOS • Payment Integration</span></div><div class="flex flex-wrap gap-1.5"><span class="px-2 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-muted)] text-xs rounded">React Native</span><span class="px-2 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-muted)] text-xs rounded">Next.js</span><span class="px-2 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-muted)] text-xs rounded">DOJO Payment API</span><span class="px-2 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-muted)] text-xs rounded">Printer Integration</span></div></div><div class="group relative p-6 rounded-2xl bg-[var(--bg-card)] border border-[var(--border-soft)] hover:border-orange-500/40 transition-all hover:-translate-y-1 hover:shadow-2xl hover:shadow-black/30 cursor-default" style="opacity:0;transform:translateY(30px)"><div class="flex items-start justify-between mb-4"><div class="w-12 h-12 rounded-xl bg-orange-500/10 flex items-center justify-center"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-package w-6 h-6 text-orange-400" aria-hidden="true"><path d="M11 21.73a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73z"></path><path d="M12 22V12"></path><polyline points="3.29 7 12 12 20.71 7"></polyline><path d="m7.5 4.27 9 5.15"></path></svg></div><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-external-link w-4 h-4 text-[var(--text-faint)] group-hover:text-[var(--text-muted)] transition-colors mt-1" aria-hidden="true"><path d="M15 3h6v6"></path><path d="M10 14 21 3"></path><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path></svg></div><div class="mb-1"><span class="text-xs font-medium text-orange-400">Logistics Mobile App</span></div><h3 class="text-[var(--text-primary)] font-semibold text-lg mb-3 leading-tight">P&amp;O Freight – Pay &amp; Go</h3><p class="text-[var(--text-muted)] text-sm leading-relaxed mb-4">Developed freight payment and management application for P&amp;O logistics with secure payment processing and shipment tracking features.</p><div class="mb-4"><span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs border bg-orange-500/10 text-orange-400 border-orange-500/20">P&amp;O Logistics • Payments</span></div><div class="flex flex-wrap gap-1.5"><span class="px-2 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-muted)] text-xs rounded">Ionic Framework</span><span class="px-2 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-muted)] text-xs rounded">Angular</span><span class="px-2 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-muted)] text-xs rounded">.NET</span></div></div><div class="group relative p-6 rounded-2xl bg-[var(--bg-card)] border border-[var(--border-soft)] hover:border-emerald-500/40 transition-all hover:-translate-y-1 hover:shadow-2xl hover:shadow-black/30 cursor-default" style="opacity:0;transform:translateY(30px)"><div class="flex items-start justify-between mb-4"><div class="w-12 h-12 rounded-xl bg-emerald-500/10 flex items-center justify-center"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-leaf w-6 h-6 text-emerald-400" aria-hidden="true"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"></path><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"></path></svg></div><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-external-link w-4 h-4 text-[var(--text-faint)] group-hover:text-[var(--text-muted)] transition-colors mt-1" aria-hidden="true"><path d="M15 3h6v6"></path><path d="M10 14 21 3"></path><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path></svg></div><div class="mb-1"><span class="text-xs font-medium text-emerald-400">AgriTech Application</span></div><h3 class="text-[var(--text-primary)] font-semibold text-lg mb-3 leading-tight">Crop Mint Mobile App</h3><p class="text-[var(--text-muted)] text-sm leading-relaxed mb-4">Built an agricultural technology mobile application with features for crop management, monitoring, and data analytics to help farmers optimize their operations.</p><div class="mb-4"><span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs border bg-emerald-500/10 text-emerald-400 border-emerald-500/20">AgriTech • Crop Management</span></div><div class="flex flex-wrap gap-1.5"><span class="px-2 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-muted)] text-xs rounded">Cordova</span><span class="px-2 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-muted)] text-xs rounded">jQuery Mobile</span><span class="px-2 py-0.5 bg-[var(--overlay-xs)] border border-[var(--border-soft)] text-[var(--text-muted)] text-xs rounded">.NET</span></div></div></div></div></section><section id="education" class="py-24 bg-[var(--bg-page)]"><div class="max-w-4xl mx-auto px-6"><div class="text-center mb-16" style="opacity:0;transform:translateY(30px)"><span class="text-indigo-400 font-mono text-sm tracking-widest uppercase">Academic background</span><h2 class="text-3xl md:text-4xl font-bold text-[var(--text-primary)] mt-3">Education</h2></div><div class="grid md:grid-cols-2 gap-6"><div class="relative p-6 rounded-2xl bg-[var(--bg-card)] border border-[var(--border-soft)] hover:border-indigo-500/30 transition-all group" style="opacity:0;transform:translateY(30px)"><div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-indigo-500/5 to-purple-500/5 opacity-0 group-hover:opacity-100 transition-opacity"></div><div class="relative flex items-start gap-5"><div class="w-14 h-14 rounded-xl bg-gradient-to-br from-indigo-600 to-purple-600 flex items-center justify-center shrink-0 shadow-lg shadow-indigo-500/20"><span class="text-white font-bold text-sm">ME</span></div><div class="flex-1"><div class="flex items-center gap-2 mb-1"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-graduation-cap w-4 h-4 text-indigo-400" aria-hidden="true"><path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z"></path><path d="M22 10v6"></path><path d="M6 12.5V16a6 3 0 0 0 12 0v-3.5"></path></svg><span class="text-indigo-400 text-sm font-medium">Master of Engineering</span></div><h3 class="text-[var(--text-primary)] font-semibold text-lg mb-1">Computer Science</h3><p class="text-[var(--text-secondary)] font-medium">Anna University</p><div class="flex items-center gap-4 mt-2 text-sm text-[var(--text-faint)]"><span class="flex items-center gap-1"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar w-3.5 h-3.5" aria-hidden="true"><path d="M8 2v4"></path><path d="M16 2v4"></path><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M3 10h18"></path></svg>2015</span><span>Tamil Nadu, India</span></div></div></div></div><div class="relative p-6 rounded-2xl bg-[var(--bg-card)] border border-[var(--border-soft)] hover:border-indigo-500/30 transition-all group" style="opacity:0;transform:translateY(30px)"><div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-indigo-500/5 to-purple-500/5 opacity-0 group-hover:opacity-100 transition-opacity"></div><div class="relative flex items-start gap-5"><div class="w-14 h-14 rounded-xl bg-gradient-to-br from-indigo-600 to-purple-600 flex items-center justify-center shrink-0 shadow-lg shadow-indigo-500/20"><span class="text-white font-bold text-sm">BE</span></div><div class="flex-1"><div class="flex items-center gap-2 mb-1"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-graduation-cap w-4 h-4 text-indigo-400" aria-hidden="true"><path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z"></path><path d="M22 10v6"></path><path d="M6 12.5V16a6 3 0 0 0 12 0v-3.5"></path></svg><span class="text-indigo-400 text-sm font-medium">Bachelor of Engineering</span></div><h3 class="text-[var(--text-primary)] font-semibold text-lg mb-1">Information Technology</h3><p class="text-[var(--text-secondary)] font-medium">Anna University</p><div class="flex items-center gap-4 mt-2 text-sm text-[var(--text-faint)]"><span class="flex items-center gap-1"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar w-3.5 h-3.5" aria-hidden="true"><path d="M8 2v4"></path><path d="M16 2v4"></path><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M3 10h18"></path></svg>2012</span><span>Tamil Nadu, India</span></div></div></div></div></div></div></section><section id="contact" class="py-24 bg-[var(--bg-alt)]"><div class="max-w-5xl mx-auto px-6"><div class="text-center mb-16" style="opacity:0;transform:translateY(30px)"><span class="text-indigo-400 font-mono text-sm tracking-widest uppercase">Let&#x27;s connect</span><h2 class="text-3xl md:text-4xl font-bold text-[var(--text-primary)] mt-3">Get In Touch</h2><p class="text-[var(--text-muted)] mt-4 max-w-xl mx-auto">I&#x27;m open to new opportunities, collaborations, and interesting projects. Drop me a message — I&#x27;ll get back to you promptly!</p></div><div class="grid lg:grid-cols-2 gap-8 items-start"><div class="grid sm:grid-cols-2 gap-4"><a href="mailto:karthikmano1111@gmail.com"><div class="group p-5 rounded-2xl bg-[var(--bg-card)] border border-[var(--border-soft)] hover:border-indigo-500/40 transition-all cursor-pointer hover:-translate-y-0.5" style="opacity:0;transform:translateY(20px)"><div class="w-10 h-10 rounded-xl bg-indigo-500/10 flex items-center justify-center mb-4"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-mail w-5 h-5 text-indigo-400" aria-hidden="true"><path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7"></path><rect x="2" y="4" width="20" height="16" rx="2"></rect></svg></div><p class="text-[var(--text-muted)] text-xs uppercase tracking-wider mb-1">Email</p><div class="flex items-center justify-between"><p class="text-sm font-medium text-indigo-400 break-all">karthikmano1111@gmail.com</p></div></div></a><a href="tel:+447733441758"><div class="group p-5 rounded-2xl bg-[var(--bg-card)] border border-[var(--border-soft)] hover:border-purple-500/40 transition-all cursor-pointer hover:-translate-y-0.5" style="opacity:0;transform:translateY(20px)"><div class="w-10 h-10 rounded-xl bg-purple-500/10 flex items-center justify-center mb-4"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-phone w-5 h-5 text-purple-400" aria-hidden="true"><path d="M13.832 16.568a1 1 0 0 0 1.213-.303l.355-.465A2 2 0 0 1 17 15h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2A18 18 0 0 1 2 4a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-.8 1.6l-.468.351a1 1 0 0 0-.292 1.233 14 14 0 0 0 6.392 6.384"></path></svg></div><p class="text-[var(--text-muted)] text-xs uppercase tracking-wider mb-1">Phone</p><div class="flex items-center justify-between"><p class="text-sm font-medium text-purple-400 break-all">+44 7733 441758</p></div></div></a><a href="https://www.linkedin.co